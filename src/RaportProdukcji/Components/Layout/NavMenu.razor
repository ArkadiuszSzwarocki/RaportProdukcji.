@rendermode InteractiveServer

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">Raport Produkcji ISA-95</a>
        <button class="navbar-toggler btn btn-outline-light ms-auto" @onclick="ToggleNav" title="Pokaż/ukryj menu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@(navOpen ? "nav-scrollable open" : "nav-scrollable")">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="planning">
                <span class="bi bi-calendar-check-nav-menu" aria-hidden="true"></span> Planowanie
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="filling">
                <span class="bi bi-box-seam-nav-menu" aria-hidden="true"></span> Zasyp
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="bagging">
                <span class="bi bi-bag-nav-menu" aria-hidden="true"></span> Workowanie
            </NavLink>
        </div>
    </nav>
</div>

@code {
    private bool navOpen = false;
    private void ToggleNav()
    {
        navOpen = !navOpen;
    }
}

