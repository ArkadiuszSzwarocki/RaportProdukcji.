@page "/planning"
@using RaportProdukcji.Models
@using RaportProdukcji.Services
@inject IProductionService ProductionService
@rendermode InteractiveServer

<PageTitle>Planowanie Produkcji</PageTitle>

<div class="container-fluid mt-4">
    <h1 class="mb-4">Planowanie Zleceń Produkcyjnych</h1>

    <div class="card mb-4">
        <div class="card-header">
            <h3>Nowe Zlecenie</h3>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Nazwa Produktu:</label>
                    <input type="text" class="form-control" @bind="newOrder.ProductName" placeholder="Nazwa produktu" />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Numer Receptury:</label>
                    <input type="text" class="form-control" @bind="newOrder.RecipeNumber" placeholder="Numer receptury" />
                </div>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Typ Worka:</label>
                    <select class="form-select" @bind="newOrder.BagType">
                        @foreach (BagType bagType in Enum.GetValues(typeof(BagType)))
                        {
                            <option value="@bagType">@bagType.GetDisplayName()</option>
                        }
                    </select>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Waga Planowa (kg):</label>
                    <input type="number" class="form-control" @bind="newOrder.PlannedWeightKg" placeholder="Waga w kg" />
                </div>
            </div>
            <div class="row">
                <div class="col-12">
                    <button class="btn btn-primary" @onclick="AddOrder">
                        <i class="bi bi-plus-circle"></i> Dodaj Zlecenie
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <h3>Lista Zleceń</h3>
        </div>
        <div class="card-body">
            @if (orders.Count == 0)
            {
                <p class="text-muted">Brak zleceń produkcyjnych.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Nazwa Produktu</th>
                                <th>Nr Receptury</th>
                                <th>Typ Worka</th>
                                <th>Waga Planowa</th>
                                <th>Wymieszano</th>
                                <th>Szarże</th>
                                <th>Czas Workowania</th>
                                <th>Status</th>
                                <th>Akcje</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in orders)
                            {
                                <tr>
                                    <td>@order.Id</td>
                                    <td>@order.ProductName</td>
                                    <td>@order.RecipeNumber</td>
                                    <td>@order.BagType.GetDisplayName()</td>
                                    <td>@order.PlannedWeightKg kg</td>
                                    <td>@order.TotalMixedWeight kg</td>
                                    <td>@order.BatchCount</td>
                                    <td>@order.EstimatedBaggingTime.ToString("F1") min</td>
                                    <td>
                                        <span class="badge bg-@GetStatusColor(order.Status)">@GetStatusText(order.Status)</span>
                                    </td>
                                    <td>
                                        <button class="btn btn-sm btn-danger" @onclick="() => DeleteOrder(order.Id)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private ProductionOrder newOrder = new();
    private List<ProductionOrder> orders = new();

    protected override void OnInitialized()
    {
        LoadOrders();
    }

    private void LoadOrders()
    {
        orders = ProductionService.GetAllOrders();
    }

    private void AddOrder()
    {
        if (string.IsNullOrWhiteSpace(newOrder.ProductName) || 
            string.IsNullOrWhiteSpace(newOrder.RecipeNumber) || 
            newOrder.PlannedWeightKg <= 0)
        {
            return;
        }

        ProductionService.AddOrder(newOrder);
        newOrder = new ProductionOrder();
        LoadOrders();
    }

    private void DeleteOrder(int orderId)
    {
        ProductionService.DeleteOrder(orderId);
        LoadOrders();
    }

    private string GetStatusColor(OrderStatus status)
    {
        return status switch
        {
            OrderStatus.Planned => "secondary",
            OrderStatus.InProgress => "primary",
            OrderStatus.ReadyForBagging => "success",
            OrderStatus.Bagging => "warning",
            OrderStatus.Completed => "info",
            _ => "secondary"
        };
    }

    private string GetStatusText(OrderStatus status)
    {
        return status switch
        {
            OrderStatus.Planned => "Planowane",
            OrderStatus.InProgress => "W trakcie",
            OrderStatus.ReadyForBagging => "Gotowe do workowania",
            OrderStatus.Bagging => "Workowanie",
            OrderStatus.Completed => "Zakończone",
            _ => status.ToString()
        };
    }
}
