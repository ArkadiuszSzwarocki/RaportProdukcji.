@page "/bagging"
@using RaportProdukcji.Models
@using RaportProdukcji.Services
@inject IProductionService ProductionService
@inject IPalletService PalletService
@rendermode InteractiveServer

<PageTitle>Workowanie</PageTitle>

<div class="container-fluid mt-4">
    <h1 class="mb-4"><i class="bi bi-box-seam"></i> Workowanie</h1>

    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="card">
                <div class="card-header bg-warning text-dark">
                    <h3>Zlecenia do Workowania</h3>
                </div>
                <div class="card-body">
                    @if (readyOrders.Count == 0)
                    {
                        <p class="text-muted">Brak zleceń gotowych do workowania.</p>
                    }
                    else
                    {
                        <div class="list-group">
                            @foreach (var order in readyOrders)
                            {
                                <a href="javascript:void(0)" 
                                   class="list-group-item list-group-item-action @(selectedOrder?.Id == order.Id ? "active" : "")"
                                   @onclick="() => SelectOrder(order)">
                                    <div class="d-flex w-100 justify-content-between">
                                        <h5 class="mb-1">@order.ProductName</h5>
                                        <small>ID: @order.Id</small>
                                    </div>
                                    <p class="mb-1">
                                        <strong>Receptura:</strong> @order.RecipeNumber<br />
                                        <strong>Typ:</strong> @order.BagType.GetDisplayName()<br />
                                        <strong>Waga:</strong> @order.TotalMixedWeight kg
                                    </p>
                                    <small class="text-@(selectedOrder?.Id == order.Id ? "white" : "muted")">
                                        Status: @GetStatusText(order.Status) | Palety: @order.Pallets.Count
                                    </small>
                                </a>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            @if (selectedOrder != null)
            {
                <div class="card">
                    <div class="card-header bg-info text-white">
                        <h3>Palety do Workowania - @selectedOrder.ProductName</h3>
                    </div>
                    <div class="card-body">
                        <div class="alert alert-info mb-3">
                            <strong>Zlecenie:</strong> @selectedOrder.ProductName<br />
                            <strong>Waga wymieszana:</strong> @selectedOrder.TotalMixedWeight kg<br />
                            <strong>Liczba szarż:</strong> @selectedOrder.BatchCount<br />
                            <strong>Status zlecenia:</strong> @GetStatusText(selectedOrder.Status)
                        </div>

                        @if (selectedOrder.Pallets.Count == 0)
                        {
                            <div class="alert alert-warning">
                                <i class="bi bi-info-circle"></i> Brak palet dla tego zlecenia.
                            </div>
                        }
                        else
                        {
                            <div class="table-responsive mb-3">
                                <table class="table table-sm table-hover">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Nr Palety</th>
                                            <th>Worki</th>
                                            <th>Waga (kg)</th>
                                            <th>Status</th>
                                            <th>Akcje</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var pallet in selectedOrder.Pallets.OrderBy(p => p.CreatedDate))
                                        {
                                            <tr>
                                                <td><strong>@pallet.PalletNumber</strong></td>
                                                <td>
                                                    <span class="badge bg-secondary">@pallet.BagCount</span>
                                                </td>
                                                <td>@pallet.TotalWeightKg kg</td>
                                                <td>
                                                    <span class="badge @GetPalletStatusBadgeClass(pallet.Status)">
                                                        @GetPalletStatusText(pallet.Status)
                                                    </span>
                                                </td>
                                                <td>
                                                    @if (pallet.Status != PalletStatus.Completed)
                                                    {
                                                        <button class="btn btn-sm btn-outline-primary" @onclick="() => AdvancePalletStatus(pallet)">
                                                            <i class="bi bi-arrow-right"></i> Dalej
                                                        </button>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>

                            <div class="d-grid gap-2">
                                @if (selectedOrder.Status == OrderStatus.ReadyForBagging)
                                {
                                    <button class="btn btn-warning btn-lg" @onclick="() => StartBagging(selectedOrder.Id)">
                                        <i class="bi bi-play-fill"></i> Rozpocznij Workowanie
                                    </button>
                                }
                                else if (selectedOrder.Status == OrderStatus.Bagging)
                                {
                                    @if (AllPalletsShipped(selectedOrder))
                                    {
                                        <button class="btn btn-success btn-lg" @onclick="() => CompleteBagging(selectedOrder.Id)">
                                            <i class="bi bi-check-circle"></i> Zakończ Zlecenie
                                        </button>
                                    }
                                    else
                                    {
                                        <div class="alert alert-info">
                                            Wszystkie palety muszą być wysłane, aby zakończyć zlecenie.
                                        </div>
                                    }
                                }
                            </div>
                        }
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-info">
                    <i class="bi bi-info-circle"></i> Wybierz zlecenie z listy po lewej stronie.
                </div>
            }
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-secondary text-white">
                    <h4>Instrukcje Workowania</h4>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <h5><i class="bi bi-clock"></i> Przybliżone czasy workowania na 1000 kg:</h5>
                            <ul>
                                <li><strong>Worki zgrzewane (20kg/25kg):</strong> 20 minut</li>
                                <li><strong>Worki szyte (20kg/25kg):</strong> 30 minut</li>
                                <li><strong>BigBag (50kg):</strong> 15 minut</li>
                            </ul>
                        </div>
                        <div class="col-md-6">
                            <h5><i class="bi bi-list-check"></i> Etapy palet:</h5>
                            <ul>
                                <li><span class="badge bg-warning text-dark">Oczekujące</span> → Paleta czeka na workowanie</li>
                                <li><span class="badge bg-info">Spakowane</span> → Paleta spakowana i gotowa</li>
                                <li><span class="badge bg-primary">Wysłane</span> → Paleta wysłana do magazynu</li>
                                <li><span class="badge bg-success">Zakończone</span> → Paleta zrealizowana</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private List<ProductionOrder> readyOrders = new();
    private ProductionOrder? selectedOrder;

    protected override void OnInitialized()
    {
        LoadOrders();
    }

    private void LoadOrders()
    {
        var allOrders = ProductionService.GetAllOrders();
        readyOrders = allOrders.Where(o => 
            o.Status == OrderStatus.ReadyForBagging || 
            o.Status == OrderStatus.Bagging).ToList();
        
        if (selectedOrder != null)
        {
            selectedOrder = ProductionService.GetOrderById(selectedOrder.Id);
        }
    }

    private void SelectOrder(ProductionOrder order)
    {
        selectedOrder = order;
    }

    private void AdvancePalletStatus(Pallet pallet)
    {
        var nextStatus = pallet.Status switch
        {
            PalletStatus.Pending => PalletStatus.Packed,
            PalletStatus.Packed => PalletStatus.Shipped,
            PalletStatus.Shipped => PalletStatus.Completed,
            _ => pallet.Status
        };

        PalletService.UpdatePalletStatus(pallet.Id, nextStatus);
        LoadOrders();
    }

    private void StartBagging(int orderId)
    {
        var order = ProductionService.GetOrderById(orderId);
        if (order != null)
        {
            order.Status = OrderStatus.Bagging;
            ProductionService.UpdateOrder(order);
            LoadOrders();
        }
    }

    private void CompleteBagging(int orderId)
    {
        var order = ProductionService.GetOrderById(orderId);
        if (order != null)
        {
            order.Status = OrderStatus.Completed;
            ProductionService.UpdateOrder(order);
            LoadOrders();
        }
    }

    private bool AllPalletsShipped(ProductionOrder order)
    {
        if (order.Pallets.Count == 0)
            return false;
        
        return order.Pallets.All(p => p.Status == PalletStatus.Shipped || p.Status == PalletStatus.Completed);
    }

    private string GetStatusText(OrderStatus status)
    {
        return status switch
        {
            OrderStatus.Planned => "Planowane",
            OrderStatus.InProgress => "W trakcie",
            OrderStatus.ReadyForBagging => "Gotowe do workowania",
            OrderStatus.Bagging => "Workowanie",
            OrderStatus.Completed => "Zakończone",
            _ => status.ToString()
        };
    }

    private string GetPalletStatusText(PalletStatus status)
    {
        return status switch
        {
            PalletStatus.Pending => "Oczekujące",
            PalletStatus.Packed => "Spakowane",
            PalletStatus.Shipped => "Wysłane",
            PalletStatus.Completed => "Zakończone",
            _ => status.ToString()
        };
    }

    private string GetPalletStatusBadgeClass(PalletStatus status)
    {
        return status switch
        {
            PalletStatus.Pending => "bg-warning text-dark",
            PalletStatus.Packed => "bg-info",
            PalletStatus.Shipped => "bg-primary",
            PalletStatus.Completed => "bg-success",
            _ => "bg-secondary"
        };
    }
}
